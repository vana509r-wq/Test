--- [ ЛОГИКА ФУНКЦИЙ ] ---

-- Хранилище для ВХ коробок
local espBoxes = {}

RunService.Heartbeat:Connect(function()
    local char = LocalPlayer.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    local root = char:FindFirstChild("HumanoidRootPart")
    if not hum or not root then return end

    -- 1. Спидхак
    if Config.SpeedHack then
        hum.WalkSpeed = Config.SpeedValue
    else
        hum.WalkSpeed = 16
    end

    -- 2. Спид Глитч (Резкие микро-телепорты вперед при ходьбе)
    if Config.SpeedGlitch and hum.MoveDirection.Magnitude > 0 then
        root.CFrame = root.CFrame + (hum.MoveDirection * 0.45)
    end

    -- 3. Мобильный Fly (Полет туда, куда смотрит камера)
    if Config.Fly then
        local vel = Vector3.new(0, 0, 0)
        if hum.MoveDirection.Magnitude > 0 then
            vel = hum.MoveDirection * Config.FlySpeed
        end
        root.Velocity = vel + Vector3.new(0, 0.4, 0) -- удерживаем в воздухе
    end

    -- 4. Флинг (Таран игроков физикой)
    if Config.Fling then
        root.Velocity = Vector3.new(0, 15000, 0) -- Бешеное вращение осей
        if char:FindFirstChild("Torso") then char.Torso.CanCollide = false
        elseif char:FindFirstChild("UpperTorso") then char.UpperTorso.CanCollide = false end
    end
end)

-- 5. Логика ВХ (ESP) без внешних библиотек
local function createESP(player)
    if player == LocalPlayer then return end
    
    local box = Drawing.new("Square")
    box.Color = Color3.fromRGB(230, 140, 0)
    box.Thickness = 1.5
    box.Filled = false
    box.Visible = false
    espBoxes[player] = box

    local conn
    conn = RunService.RenderStepped:Connect(function()
        if not Config.ESP or not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then
            box.Visible = false
            if not player.Parent then 
                box:Destroy()
                conn:Disconnect()
            end
            return
        end

        local root = player.Character.HumanoidRootPart
        local pos, onScreen = Camera:WorldToViewportPoint(root.Position)

        if onScreen then
            local sizeY = 2500 / pos.Z
            local sizeX = 1700 / pos.Z
            box.Size = Vector2.new(sizeX, sizeY)
            box.Position = Vector2.new(pos.X - sizeX / 2, pos.Y - sizeY / 2)
            box.Visible = true
        else
            box.Visible = false
        end
    end)
end

Players.PlayerAdded:Connect(createESP)
for _, p in pairs(Players:GetPlayers()) do createESP(p) end

