-- ВХ (Wallhack / ESP)
local espBoxes = {}
Tabs.Visuals:AddToggle("ESPToggle", {
    Title = "Включить ВХ (ESP Boxes)",
    Default = false,
    Callback = function(Value)
        if not Value then
            for _, box in pairs(espBoxes) do if box then box:Destroy() end end
            table.clear(espBoxes)
        end
        _G.ESP = Value
    end
})

-- Логика циклов функций
RunService.RenderStepped:Connect(function()
    local character = LocalPlayer.Character
    if not character then return end
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not humanoid or not rootPart then return end

    -- Спидхак
    if isSpeedHack then
        humanoid.WalkSpeed = walkSpeed
    end

    -- Speed Glitch
    if isSpeedGlitch and humanoid.MoveDirection.Magnitude > 0 then
        rootPart.CFrame = rootPart.CFrame + (humanoid.MoveDirection * (speedGlitchFactor / 10))
    end

    -- Полет (Fly)
    if isFly then
        local targetVelocity = Vector3.new(0, 0, 0)
        if humanoid.MoveDirection.Magnitude > 0 then
            targetVelocity = humanoid.MoveDirection * flySpeed
        end
        -- Удерживаем высоту, если не двигаемся
        rootPart.Velocity = targetVelocity + Vector3.new(0, 0.5, 0)
    end

    -- Флинг (Fling)
    if isFling then
        -- Создаем бешеную угловую скорость для симуляции физического взрыва при касании
        rootPart.Velocity = Vector3.new(0, 9999, 0)
        if character:FindFirstChild("Torso") then
            character.Torso.CanCollide = false
        elseif character:FindFirstChild("UpperTorso") then
            character.UpperTorso.CanCollide = false
        end
    end
end)

-- Логика ВХ (ESP)
local function createESP(player)
    if player == LocalPlayer then return end
    local box = Drawing.new("Square")
    box.Color = Color3.fromRGB(255, 20, 147) -- Красивый розовый/медовый цвет
    box.Thickness = 2
    box.Filled = false
    box.Visible = false
    table.insert(espBoxes, box)

    local connection
    connection = RunService.RenderStepped:Connect(function()
        if not _G.ESP or not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then
            box.Visible = false
            if not _G.ESP and connection then connection:Disconnect() end
            return
        end

        local rootPart = player.Character.HumanoidRootPart
        local position, onScreen = game.Workspace.CurrentCamera:WorldToViewportPoint(rootPart.Position)

        if onScreen then
            box.Size = Vector2.new(2000 / position.Z, 3000 / position.Z)
            box.Position = Vector2.new(position.X - box.Size.X / 2, position.Y - box.Size.Y / 2)
            box.Visible = true
        else
            box.Visible = false
        end
    end)
end

for _, p in pairs(Players:GetPlayers()) do createESP(p) end
Players.PlayerAdded:Connect(createESP)

